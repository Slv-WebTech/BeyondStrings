# WhatsApp Chat UI - Environment Variables
# Copy this file to .env.local and add your actual API keys
# IMPORTANT: .env.local is in .gitignore - never commit API keys!

# OpenAI API Configuration
# Required for: AI-powered conversation summarization
# Get your key from: https://platform.openai.com/account/api-keys
# Leave empty or omit this line to use local-only summarization (no API key needed)
VITE_OPENAI_API_KEY=sk_replace_with_your_actual_api_key_here

# Optional free local AI via Ollama
# Install Ollama from: https://ollama.com/
# Start Ollama server and pull a model, e.g.:
#   ollama pull llama3.2:3b
# If OpenAI key is missing or fails, app tries Ollama before rule-based local summary.
VITE_OLLAMA_BASE_URL=http://127.0.0.1:11434
VITE_OLLAMA_MODEL=llama3.2:3b

# Notes:
# - The app works perfectly fine without an OpenAI API key
# - If no OpenAI key is provided, the app tries Ollama (if available) then local summarizer
# - OpenAI API calls require a paid account (free tier has limited quota)
# - For development: Set up a .env.local file in the project root
# - For production: Use environment variables or GitHub Secrets
